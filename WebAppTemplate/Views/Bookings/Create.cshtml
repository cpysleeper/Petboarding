@model WebAppTemplate.Models.BookingCreateViewModel

@{
    ViewBag.Title = "New Booking";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>New Booking</h2>

@using (Html.BeginForm("Create", "Bookings", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="form-group">
        @Html.LabelFor(m => m.PetId, "Pet")
        @Html.DropDownListFor(m => m.PetId, Model.Pets, "-- Select Pet --", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.PetId, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.BookingStartTime, "Start Time")
        @Html.TextBoxFor(m => m.BookingStartTime, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
        @Html.ValidationMessageFor(m => m.BookingStartTime, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.BookingEndTime, "End Time")
        @Html.TextBoxFor(m => m.BookingEndTime, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
        @Html.ValidationMessageFor(m => m.BookingEndTime, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.CheckInMethod, "Check-In Method")
        @Html.TextBoxFor(m => m.CheckInMethod, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.CheckInMethod, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.CheckOutMethod, "Check-Out Method")
        @Html.TextBoxFor(m => m.CheckOutMethod, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.CheckOutMethod, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.SpecialInstructions, "Special Instructions")
        @Html.TextAreaFor(m => m.SpecialInstructions, new { @class = "form-control", rows = 4 })
    </div>

    <button type="submit" class="btn btn-primary">Create Booking</button>
    @Html.ActionLink("Cancel", "Index", "Bookings", null, new { @class = "btn btn-default" })
}