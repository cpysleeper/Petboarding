@model WebAppTemplate.Models.PetDetailsViewModel

@{
    ViewBag.Title = "Pet Details";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>@Model.Name</h2>

<div>
    <p><strong>Species:</strong> @Model.Species</p>
    <p><strong>Breed:</strong> @Model.Breed</p>
    <p><strong>Age:</strong> @Model.Age</p>
    <p><strong>Sex:</strong> @Model.Sex</p>
    <p><strong>Weight:</strong> @Model.Weight</p>
    <p><strong>Color:</strong> @Model.Color</p>
    <p><strong>Notes:</strong> @Model.Notes</p>
</div>

<hr />

<h3>Owner Information</h3>

<p><strong>Name:</strong> @Model.OwnerName</p>
<p><strong>Email:</strong> @Model.OwnerEmail</p>
<p><strong>Phone:</strong> @Model.OwnerPhone</p>

<hr />

<h3>Care Information</h3>

<p>
    @Html.ActionLink(
        "View / Edit Emergency Contacts",
        "Index",
        "PetEmergencyContacts",
        new { petId = Model.PetId },
        new { @class = "btn btn-primary" }
     )
</p>

<p>
    @Html.ActionLink(
        "View / Edit Feeding Plans",
        "Index",
        "PetFeedingPlans",
        new { petId = Model.PetId },
        new { @class = "btn btn-primary" }
    )
</p>

<p>
    @Html.ActionLink(
        "View / Edit Medications",
        "Index",
        "PetMedications",
        new { petId = Model.PetId },
        new { @class = "btn btn-primary" }
    )
</p>

<hr />

@Html.ActionLink("Back", "Index", "Pets", null, new { @class = "btn btn-secondary" })