@model WebAppTemplate.Models.MedicationListViewModel

@{
    ViewBag.Title = "Medications";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Medications</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    @Html.ActionLink("+ Add Medication", "Create", "PetMedications",
        new { petId = Model.PetId },
        new { @class = "btn btn-primary" })
</p>

<table class="table">
    <tr>
        <th>Medication</th>
        <th>Dosage</th>
        <th>Frequency</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model.Medications)
    {
        <tr>
            <td>@item.MedicationName</td>
            <td>@item.Dosage</td>
            <td>@item.Frequency</td>
            <td>
                @Html.ActionLink("Edit", "Edit", "PetMedications",
                    new { id = item.PetMedicationId },
                    new { @class = "btn btn-warning" })

                @Html.ActionLink("Delete", "Delete", "PetMedications",
                    new { id = item.PetMedicationId },
                    new { @class = "btn btn-danger", onclick = "return confirm('Delete this medication?');" })
            </td>
        </tr>
    }
</table>

@Html.ActionLink("Back", "Details", "Pets",
    new { id = Model.PetId },
    new { @class = "btn btn-secondary" })