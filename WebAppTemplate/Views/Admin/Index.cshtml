@model WebAppTemplate.Models.AdminDashboardViewModel

@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Admin Dashboard</h2>

<p>
    @Html.ActionLink("+ Create Employee", "CreateEmployee", "Admin", null, new { @class = "btn btn-primary" })
</p>

@if (Model.Employees == null || !Model.Employees.Any())
{
    <p>No employees found.</p>
}
else
{
    <table class="table table-bordered table-striped">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>

        @foreach (var employee in Model.Employees)
        {
            <tr>
                <td>@employee.FullName</td>
                <td>@employee.Email</td>
                <td>@employee.Role</td>
                <td>@(employee.IsActive ? "Active" : "Inactive")</td>
                <td>@employee.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                     @Html.ActionLink("Edit", "EditEmployee", "Admin",
                        new { id = employee.EmployeeId },
                        new { @class = "btn btn-warning btn-sm" })

                    @Html.ActionLink("Delete", "DeleteEmployee", "Admin",
                        new { id = employee.EmployeeId },
                        new { @class = "btn btn-danger btn-sm", onclick = "return confirm('Delete this employee?');" })
                </td>
            </tr>
        }
    </table>
}