@model WebAppTemplate.Models.OwnerDashboardViewModel

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewBag.Title = "Owner Dashboard";
}

<div class="owner-dashboard">
    <p class="dashboard-title">Owner Dashboard</p>

    <h1 class="welcome-title">Welcome back, @Model.OwnerName!</h1>

    <p>Manage your pets' information and bookings with ease.</p>

    <div class="dashboard-actions">
        @Html.ActionLink("🐾 My Pets", "Index", "Pets", null, new { @class = "dashboard-btn" })
        @Html.ActionLink("▣ My Bookings", "Index", "Bookings", null, new { @class = "dashboard-btn" })
        @Html.ActionLink("+ New Booking", "NewBooking", "MyAccount", null, new { @class = "dashboard-btn" })
    </div>
</div>

<style>
    .dashboard-actions {
        display: flex;
        gap: 12px;
        margin: 20px 0;
    }

    .dashboard-btn {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 8px;
        border: 1px solid #d0d7de;
        background-color: #f6f8fa;
        color: #24292f;
        text-decoration: none;
        font-weight: 500;
    }

        .dashboard-btn:hover {
            background-color: #eaeef2;
            text-decoration: none;
            color: #0969da;
        }

    .dashboard-btn-primary {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }

        .dashboard-btn-primary:hover {
            background-color: #0b5ed7;
            color: white;
        }

    .next-booking-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 16px;
        margin-top: 12px;
        background: #f8f9fa;
        max-width: 500px;
    }
</style>