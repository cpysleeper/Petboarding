@model CozyPawsPetboarding.Models.BookingListViewModel

@{
    ViewBag.Title = "My Bookings";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>My Bookings</h2>

<p>
    @Html.ActionLink("+ New Booking", "Create", "Bookings", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Pet</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Actions</th>
            <th>Updated By</th>
            <th>Updated At</th>
        </tr>
    </thead>

    <tbody>
        @if (Model.Bookings != null && Model.Bookings.Any())
        {
            foreach (var booking in Model.Bookings)
            {
                <tr>
                    <td>@booking.PetName</td>
                    <td>@booking.StartTime.ToString("MMM dd, yyyy")</td>
                    <td>@booking.EndTime.ToString("MMM dd, yyyy")</td>
                    <td>@booking.Status</td>
                    <td>
                        @(string.IsNullOrWhiteSpace(booking.UpdatedByEmployeeName)
                        ? "Not updated yet"
                        : booking.UpdatedByEmployeeName)
                    </td>

                    <td>
                        @(booking.StatusUpdatedAt.HasValue
                        ? booking.StatusUpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")
                        : "-")
                    </td>
                    <td>
                        @Html.ActionLink("View", "Details", "Bookings", new { id = booking.BookingId }, new { @class = "btn btn-info btn-sm" })

                        @Html.ActionLink("Request Cancel", "RequestCancel", "Bookings", new { id = booking.BookingId }, new { @class = "btn btn-warning btn-sm" })
                        {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-warning btn-sm">Request Cancel</button>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5">You do not have any bookings yet.</td>
            </tr>
        }
    </tbody>
</table>