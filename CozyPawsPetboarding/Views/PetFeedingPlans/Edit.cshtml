@model CozyPawsPetboarding.Models.FeedingPlanEditViewModel

@{
    ViewBag.Title = "Edit Feeding Plan";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Edit Feeding Plan</h2>

@using (Html.BeginForm("Edit", "PetFeedingPlans", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    @Html.HiddenFor(m => m.PetFeedingPlanId)
    @Html.HiddenFor(m => m.PetId)

    <div class="form-group">
        @Html.LabelFor(m => m.FeedingsPerDay)
        @Html.TextBoxFor(m => m.FeedingsPerDay, new { @class = "form-control", type = "number" })
        @Html.ValidationMessageFor(m => m.FeedingsPerDay, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.AmountPerFeeding)
        @Html.TextBoxFor(m => m.AmountPerFeeding, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.AmountPerFeeding, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.FoodBrand)
        @Html.TextBoxFor(m => m.FoodBrand, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.FoodBrand, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.FeedingInstructions)
        @Html.TextAreaFor(m => m.FeedingInstructions, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.FeedingInstructions, "", new { @class = "text-danger" })
    </div>

    <div class="form-check">
        @Html.CheckBoxFor(m => m.HasSpecialDiet, new { @class = "form-check-input" })
        @Html.LabelFor(m => m.HasSpecialDiet, new { @class = "form-check-label" })
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Save</button>

    @Html.ActionLink("Cancel", "Index", "PetFeedingPlans",
        new { petId = Model.PetId },
        new { @class = "btn btn-secondary" })
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}