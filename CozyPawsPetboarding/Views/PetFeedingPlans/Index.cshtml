@model CozyPawsPetboarding.Models.FeedingPlanListViewModel

@{
    ViewBag.Title = "Feeding Plans";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<h2>Feeding Plans</h2>

<p>
    @Html.ActionLink("+ Add Feeding Plan", "Create", "PetFeedingPlans",
        new { petId = Model.PetId },
        new { @class = "btn btn-primary" })
</p>

<table class="table">
    <tr>
        <th>Feedings Per Day</th>
        <th>Amount Per Feeding</th>
        <th>Food Brand</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model.Plans)
    {
        <tr>
            <td>@item.FeedingsPerDay</td>
            <td>@item.AmountPerFeeding</td>
            <td>@item.FoodBrand</td>
            <td>
                @Html.ActionLink("Edit", "Edit", "PetFeedingPlans",
                    new { id = item.PetFeedingPlanId },
                    new { @class = "btn btn-warning" })

                @Html.ActionLink("Delete", "Delete", "PetFeedingPlans",
                    new { id = item.PetFeedingPlanId },
                    new { @class = "btn btn-danger", onclick = "return confirm('Delete this feeding plan?');" })
            </td>
        </tr>
    }
</table>

@Html.ActionLink("Back", "Details", "Pets",
    new { id = Model.PetId },
    new { @class = "btn btn-secondary" })